<template>
  <div
    class="flex justify-center items-center min-h-screen"
  >
    Loading...
  </div>
</template>

<script>
export default {
  name: 'TNSkillsSSOPage',

  async mounted() {
    try {
      const ssoToken = this.$route.query.token;

      if (!ssoToken) {
        this.$router.push('/login');
        return;
      }

      const response = await this.$store.dispatch(
        'verifyTNSkillsSSO',
        ssoToken
      );

      if (response.user_exists) {
        localStorage.setItem(
          'token',
          response.access
        );

        localStorage.setItem(
          'refresh',
          response.refresh
        );

        await this.$store.dispatch(
          'fetchProfileDetails'
        );

        this.$router.push('/');
      } else {
        this.$router.push('/login');
      }

    } catch (error) {
      console.error(error);
      this.$router.push('/login');
    }
  },
};
</script>









